<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bright Future School</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Header -->
    <header>
        <nav>
            <h1>Bright Future School</h1>
            <ul>
                <li><a href="#home">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#courses">Courses</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
    </header>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <h2>Welcome to Bright Future School</h2>
        <p>Building Leaders for Tomorrow</p>
        <button onclick="showMessage()">Apply Now</button>
    </section>

    <!-- About Section -->
    <section id="about" class="section">
        <h2>About Us</h2>
        <p>
            Bright Future School provides quality education and develops
            students academically, morally, and socially.
        </p>
    </section>

    <!-- Courses Section -->
    <section id="courses" class="section">
        <h2>Our Programs</h2>

        <div class="cards">
            <div class="card">
                <h3>Science</h3>
                <p>Physics, Chemistry, Biology, Mathematics.</p>
            </div>

            <div class="card">
                <h3>Arts</h3>
                <p>Literature, Government, CRS, History.</p>
            </div>

            <div class="card">
                <h3>Commercial</h3>
                <p>Economics, Accounting, Commerce.</p>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="section">
        <h2>Contact Us</h2>
        <p>Email: info@brightfuture.edu</p>
        <p>Phone: +234 800 000 0000</p>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2026 Bright Future School. All Rights Reserved.</p>
    </footer>

    <script src="script.js"></script>

</body>
</html>
